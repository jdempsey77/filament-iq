# Copy to scripts/deploy.env and fill in values. Never commit deploy.env.
SSH_HOST=192.168.x.x
SSH_USER=root
SSH_OPTS=-o StrictHostKeyChecking=accept-new
REMOTE_CONFIG_PATH=/config
HOME_ASSISTANT_URL=http://192.168.x.x:8123
HOME_ASSISTANT_TOKEN=your_long_lived_token_here
APPDAEMON_ADDON_SLUG=a0d7b954_appdaemon
SPOOLMAN_URL=http://192.168.x.x:7912
