# SSH deploy config for Home Assistant
# Copy to deploy.env and fill in values. deploy.env is gitignored.

# SSH connection
SSH_HOST=homeassistant.local
SSH_USER=root
REMOTE_CONFIG_PATH=/config

# Optional: custom SSH options (e.g. port, key file)
# SSH_OPTS="-o Port=22222 -i ~/.ssh/ha_key"

# Optional: for Lovelace reload / validate / restart
# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=your_long_lived_access_token

# Optional: go2rtc config path (default: REMOTE_CONFIG_PATH/go2rtc.yaml)
# REMOTE_GO2RTC_PATH=/config/go2rtc.yaml

# Optional: Spoolman base URL for --spoolman-export and --spoolman-import (e.g. http://host:7912)
# SPOOLMAN_URL=http://192.168.1.10:7912
