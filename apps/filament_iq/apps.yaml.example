# apps.yaml.example — FilamentIQ AppDaemon configuration
#
# Copy this file to your AppDaemon apps.yaml and replace:
#   YOUR_PRINTER_IP      → Bambu printer LAN IP (e.g. 192.168.4.50)
#   YOUR_SPOOLMAN_IP     → Spoolman server IP (e.g. 192.168.1.250)
#
# Also replace YOUR_PRINTER_SERIAL in the Python source files
# (ams_print_usage_sync.py, ams_rfid_reconcile.py) with your
# Bambu printer's device serial from ha-bambulab entity IDs.
#
# Advanced tuning keys (debounce, thresholds, poll intervals, etc.)
# have sensible defaults and are documented in the source of each app.

ams_print_usage_sync:
  module: ams_print_usage_sync
  class: AmsPrintUsageSync
  enabled: true
  spoolman_base_url: "http://YOUR_SPOOLMAN_IP:7912"
  dry_run: false
  printer_ip: "YOUR_PRINTER_IP"
  access_code_entity: "input_text.bambu_printer_access_code"
  threemf_enabled: true
  # printer_access_code: ""  # optional; overrides entity if set

ams_rfid_reconcile:
  module: ams_rfid_reconcile
  class: AmsRfidReconcile
  enabled: true
  spoolman_url: "http://YOUR_SPOOLMAN_IP:7912"
  startup_delay_seconds: 60
  debug_logs: false

ams_rfid_guard:
  module: ams_rfid_guard
  class: AmsRfidGuard
  enabled: true
  spoolman_base_url: "http://YOUR_SPOOLMAN_IP:7912"
  dry_run: false

filament_weight_tracker:
  module: filament_weight_tracker
  class: FilamentWeightTracker
  spoolman_url: "http://YOUR_SPOOLMAN_IP:7912"

spoolman_dropdown_sync:
  module: spoolman_dropdown_sync
  class: SpoolmanDropdownSync
  enabled: true
  spoolman_base_url: "http://YOUR_SPOOLMAN_IP:7912"
